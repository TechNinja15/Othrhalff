## 3. Row Level Security (RLS) Policies
```sql
alter table public.user_presence enable row level security;
alter table public.blocked_users enable row level security;
alter table public.profiles enable row level security;
alter table public.swipes enable row level security;
alter table public.matches enable row level security;
alter table public.messages enable row level security;
alter table public.confessions enable row level security;
alter table public.confession_comments enable row level security;
alter table public.confession_reactions enable row level security;
alter table public.poll_options enable row level security;
alter table public.poll_votes enable row level security;
alter table public.glimpses enable row level security;
alter table public.glimpse_reactions enable row level security;
alter table public.notifications enable row level security;
alter table public.call_sessions enable row level security;
alter table public.active_rooms enable row level security;
alter table public.verification_requests enable row level security;
alter table public.support_tickets enable row level security;
alter table public.career_inquiries enable row level security;

-- Policy: Allow public delete access to active_rooms on active_rooms
create policy "Allow public delete access to active_rooms" on public.active_rooms
  for delete
  to public
  using (true)
;

-- Policy: Allow public insert access to active_rooms on active_rooms
create policy "Allow public insert access to active_rooms" on public.active_rooms
  for insert
  to public
  with check (true)
;

-- Policy: Allow public read access to active_rooms on active_rooms
create policy "Allow public read access to active_rooms" on public.active_rooms
  for select
  to public
  using (true)
;

-- Policy: Allow public update access to active_rooms on active_rooms
create policy "Allow public update access to active_rooms" on public.active_rooms
  for update
  to public
  using (true)
;

-- Policy: Users can create blocks on blocked_users
create policy "Users can create blocks" on public.blocked_users
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = blocker_id))
;

-- Policy: Users can delete their blocks on blocked_users
create policy "Users can delete their blocks" on public.blocked_users
  for delete
  to public
  using ((( SELECT auth.uid() AS uid) = blocker_id))
;

-- Policy: Users can view blocks they created on blocked_users
create policy "Users can view blocks they created" on public.blocked_users
  for select
  to public
  using ((( SELECT auth.uid() AS uid) = blocker_id))
;

-- Policy: Callers can create call sessions on call_sessions
create policy "Callers can create call sessions" on public.call_sessions
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = caller_id))
;

-- Policy: Users can update their call sessions on call_sessions
create policy "Users can update their call sessions" on public.call_sessions
  for update
  to public
  using (((( SELECT auth.uid() AS uid) = caller_id) OR (( SELECT auth.uid() AS uid) = receiver_id)))
;

-- Policy: Users can view their own call sessions on call_sessions
create policy "Users can view their own call sessions" on public.call_sessions
  for select
  to public
  using (((( SELECT auth.uid() AS uid) = caller_id) OR (( SELECT auth.uid() AS uid) = receiver_id)))
;

-- Policy: Anyone can submit career inquiry on career_inquiries
create policy "Anyone can submit career inquiry" on public.career_inquiries
  for insert
  to public
  with check (true)
;

-- Policy: Comment on confession_comments
create policy "Comment" on public.confession_comments
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Read comments on confession_comments
create policy "Read comments" on public.confession_comments
  for select
  to public
  using (true)
;

-- Policy: Users can insert comments on confession_comments
create policy "Users can insert comments" on public.confession_comments
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: React on confession_reactions
create policy "React" on public.confession_reactions
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Read reactions on confession_reactions
create policy "Read reactions" on public.confession_reactions
  for select
  to public
  using (true)
;

-- Policy: Authenticated users can view all confessions on confessions
create policy "Authenticated users can view all confessions" on public.confessions
  for select
  to authenticated
  using (true)
;

-- Policy: Insert confessions on confessions
create policy "Insert confessions" on public.confessions
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Read all confessions on confessions
create policy "Read all confessions" on public.confessions
  for select
  to public
  using (true)
;

-- Policy: Reactions are viewable by authenticated users on glimpse_reactions
create policy "Reactions are viewable by authenticated users" on public.glimpse_reactions
  for select
  to public
  using ((auth.role() = 'authenticated'::text))
;

-- Policy: Users can insert reactions on glimpse_reactions
create policy "Users can insert reactions" on public.glimpse_reactions
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Glimpses are viewable by authenticated users on glimpses
create policy "Glimpses are viewable by authenticated users" on public.glimpses
  for select
  to public
  using ((auth.role() = 'authenticated'::text))
;

-- Policy: Users can delete their own glimpses on glimpses
create policy "Users can delete their own glimpses" on public.glimpses
  for delete
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can insert their own glimpses on glimpses
create policy "Users can insert their own glimpses" on public.glimpses
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can insert matches on matches
create policy "Users can insert matches" on public.matches
  for insert
  to public
  with check (((( SELECT auth.uid() AS uid) = user_a) OR (( SELECT auth.uid() AS uid) = user_b)))
;

-- Policy: Users can trigger match creation on matches
create policy "Users can trigger match creation" on public.matches
  for insert
  to public
  with check (((( SELECT auth.uid() AS uid) = user_a) AND (EXISTS ( SELECT 1
   FROM swipes s
  WHERE ((s.liker_id = matches.user_b) AND (s.target_id = ( SELECT auth.uid() AS uid)) AND (s.action = 'like'::text))))))
;

-- Policy: Users can view their own matches on matches
create policy "Users can view their own matches" on public.matches
  for select
  to public
  using (((( SELECT auth.uid() AS uid) = user_a) OR (( SELECT auth.uid() AS uid) = user_b)))
;

-- Policy: Users can delete messages they sent on messages
create policy "Users can delete messages they sent" on public.messages
  for delete
  to public
  using ((( SELECT auth.uid() AS uid) = sender_id))
;

-- Policy: Users can insert messages in their matches on messages
create policy "Users can insert messages in their matches" on public.messages
  for insert
  to public
  with check ((EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid)))))))
;

-- Policy: Users can insert messages into their matches on messages
create policy "Users can insert messages into their matches" on public.messages
  for insert
  to public
  with check (((sender_id = ( SELECT auth.uid() AS uid)) AND (EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid))))))))
;

-- Policy: Users can insert messages to their matches on messages
create policy "Users can insert messages to their matches" on public.messages
  for insert
  to public
  with check (((sender_id = ( SELECT auth.uid() AS uid)) AND (EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid))))))))
;

-- Policy: Users can read messages in their matches on messages
create policy "Users can read messages in their matches" on public.messages
  for select
  to authenticated
  using (true)
;

-- Policy: Users can send messages to their matches on messages
create policy "Users can send messages to their matches" on public.messages
  for insert
  to public
  with check (((sender_id = ( SELECT auth.uid() AS uid)) AND (EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid))))))))
;

-- Policy: Users can update their own received messages on messages
create policy "Users can update their own received messages" on public.messages
  for update
  to public
  using ((EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid)))))))
;

-- Policy: Users can view messages for their matches on messages
create policy "Users can view messages for their matches" on public.messages
  for select
  to public
  using ((EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid)))))))
;

-- Policy: Users can view messages from their matches on messages
create policy "Users can view messages from their matches" on public.messages
  for select
  to public
  using ((EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid)))))))
;

-- Policy: Users can view messages in their matches on messages
create policy "Users can view messages in their matches" on public.messages
  for select
  to public
  using ((EXISTS ( SELECT 1
   FROM matches
  WHERE ((matches.id = messages.match_id) AND ((matches.user_a = ( SELECT auth.uid() AS uid)) OR (matches.user_b = ( SELECT auth.uid() AS uid)))))))
;

-- Policy: Users can delete their own notifications on notifications
create policy "Users can delete their own notifications" on public.notifications
  for delete
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can insert own notifications on notifications
create policy "Users can insert own notifications" on public.notifications
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can insert their own notifications on notifications
create policy "Users can insert their own notifications" on public.notifications
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can read own notifications on notifications
create policy "Users can read own notifications" on public.notifications
  for select
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can update their own notifications on notifications
create policy "Users can update their own notifications" on public.notifications
  for update
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can view their own notifications on notifications
create policy "Users can view their own notifications" on public.notifications
  for select
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Insert options on poll_options
create policy "Insert options" on public.poll_options
  for insert
  to public
  with check ((EXISTS ( SELECT 1
   FROM confessions
  WHERE ((confessions.id = poll_options.confession_id) AND (confessions.user_id = ( SELECT auth.uid() AS uid))))))
;

-- Policy: Read options on poll_options
create policy "Read options" on public.poll_options
  for select
  to public
  using (true)
;

-- Policy: Read votes on poll_votes
create policy "Read votes" on public.poll_votes
  for select
  to public
  using (true)
;

-- Policy: Vote on poll_votes
create policy "Vote" on public.poll_votes
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Public profiles are viewable by authenticated users on profiles
create policy "Public profiles are viewable by authenticated users" on public.profiles
  for select
  to authenticated
  using (true)
;

-- Policy: Public profiles are viewable by everyone on profiles
create policy "Public profiles are viewable by everyone" on public.profiles
  for select
  to public
  using (true)
;

-- Policy: Users can insert their own profile on profiles
create policy "Users can insert their own profile" on public.profiles
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = id))
;

-- Policy: Users can update their own profile on profiles
create policy "Users can update their own profile" on public.profiles
  for update
  to public
  using ((( SELECT auth.uid() AS uid) = id))
;

-- Policy: Users can insert their own support tickets on support_tickets
create policy "Users can insert their own support tickets" on public.support_tickets
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can view their own support tickets on support_tickets
create policy "Users can view their own support tickets" on public.support_tickets
  for select
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Allow read own swipes on swipes
create policy "Allow read own swipes" on public.swipes
  for select
  to public
  using ((( SELECT auth.uid() AS uid) = liker_id))
;

-- Policy: Allow upsert own swipes on swipes
create policy "Allow upsert own swipes" on public.swipes
  for all
  to public
  with check ((( SELECT auth.uid() AS uid) = liker_id))
;

-- Policy: Allow read all presence on user_presence
create policy "Allow read all presence" on public.user_presence
  for select
  to public
  using (true)
;

-- Policy: Allow upsert own presence on user_presence
create policy "Allow upsert own presence" on public.user_presence
  for all
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can insert their own verification requests on verification_requests
create policy "Users can insert their own verification requests" on public.verification_requests
  for insert
  to public
  with check ((( SELECT auth.uid() AS uid) = user_id))
;

-- Policy: Users can view their own verification requests on verification_requests
create policy "Users can view their own verification requests" on public.verification_requests
  for select
  to public
  using ((( SELECT auth.uid() AS uid) = user_id))
;

```

