# Othrhalff Database Infrastructure

This document contains the complete SQL schema required to recreate the Supabase database for Othrhalff. It includes all tables, relationships, Row Level Security (RLS) policies, triggers, and RPC functions (Stored Procedures) used by the application.

If the database is ever deleted, running this entire SQL script will recreate the exact structure required for the application to function perfectly.

---

## 1. Enable Extensions
```sql
create extension if not exists "uuid-ossp";
```

## 2. Table Definitions
```sql
-- Table: public.active_rooms
create table public.active_rooms (
  room_id text not null,
  host_peer_id text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  updated_at timestamp with time zone default timezone('utc'::text, now()),
  is_private boolean default false,
  passcode text,
  participant_count integer default 1,
  constraint active_rooms_pkey PRIMARY KEY (room_id)
);

-- Table: public.blocked_users
create table public.blocked_users (
  id uuid not null default gen_random_uuid(),
  blocker_id uuid,
  blocked_id uuid,
  created_at timestamp with time zone default now(),
  constraint blocked_users_blocked_id_fkey FOREIGN KEY (blocked_id) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint blocked_users_blocker_id_blocked_id_key UNIQUE (blocker_id, blocked_id),
  constraint blocked_users_blocker_id_fkey FOREIGN KEY (blocker_id) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint blocked_users_pkey PRIMARY KEY (id)
);

-- Table: public.call_sessions
create table public.call_sessions (
  id uuid not null default gen_random_uuid(),
  caller_id uuid,
  receiver_id uuid,
  match_id uuid,
  channel_name text,
  token text,
  app_id text,
  status USER-DEFINED default 'ringing'::call_status,
  created_at timestamp with time zone default now(),
  answered_at timestamp with time zone,
  ended_at timestamp with time zone,
  call_type text default 'video'::text,
  constraint call_sessions_caller_id_fkey FOREIGN KEY (caller_id) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint call_sessions_match_id_fkey FOREIGN KEY (match_id) REFERENCES matches(id) ON DELETE CASCADE,
  constraint call_sessions_pkey PRIMARY KEY (id),
  constraint call_sessions_receiver_id_fkey FOREIGN KEY (receiver_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.career_inquiries
create table public.career_inquiries (
  id uuid not null default gen_random_uuid(),
  role text,
  full_name text,
  phone text,
  email text,
  college text,
  created_at timestamp with time zone default now(),
  status text default 'pending'::text,
  constraint career_inquiries_pkey PRIMARY KEY (id)
);

-- Table: public.confession_comments
create table public.confession_comments (
  id uuid not null default gen_random_uuid(),
  confession_id uuid,
  user_id uuid,
  text text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  constraint confession_comments_confession_id_fkey FOREIGN KEY (confession_id) REFERENCES confessions(id) ON DELETE CASCADE,
  constraint confession_comments_pkey PRIMARY KEY (id),
  constraint confession_comments_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.confession_reactions
create table public.confession_reactions (
  id uuid not null default gen_random_uuid(),
  confession_id uuid,
  user_id uuid,
  emoji text,
  constraint confession_reactions_confession_id_fkey FOREIGN KEY (confession_id) REFERENCES confessions(id) ON DELETE CASCADE,
  constraint confession_reactions_pkey PRIMARY KEY (id),
  constraint confession_reactions_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint one_reaction_per_user_per_confession UNIQUE (confession_id, user_id)
);

-- Table: public.confessions
create table public.confessions (
  id uuid not null default gen_random_uuid(),
  user_id uuid,
  university text,
  text text,
  image_url text,
  type text default 'text'::text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  constraint confessions_pkey PRIMARY KEY (id),
  constraint confessions_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.glimpse_reactions
create table public.glimpse_reactions (
  id uuid not null default gen_random_uuid(),
  glimpse_id uuid,
  user_id uuid,
  reaction_type text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  constraint glimpse_reactions_glimpse_id_fkey FOREIGN KEY (glimpse_id) REFERENCES glimpses(id) ON DELETE CASCADE,
  constraint glimpse_reactions_glimpse_id_user_id_reaction_type_key UNIQUE (glimpse_id, user_id, reaction_type),
  constraint glimpse_reactions_pkey PRIMARY KEY (id),
  constraint glimpse_reactions_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.glimpses
create table public.glimpses (
  id uuid not null default gen_random_uuid(),
  user_id uuid,
  image_path text,
  caption text,
  university text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  is_anonymous boolean default false,
  constraint glimpses_pkey PRIMARY KEY (id),
  constraint glimpses_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.matches
create table public.matches (
  id uuid not null default gen_random_uuid(),
  user_a uuid,
  user_b uuid,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  is_revealed boolean default false,
  constraint matches_pkey PRIMARY KEY (id),
  constraint matches_user_a_fkey FOREIGN KEY (user_a) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint matches_user_a_user_b_key UNIQUE (user_a, user_b),
  constraint matches_user_b_fkey FOREIGN KEY (user_b) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.messages
create table public.messages (
  id uuid not null default gen_random_uuid(),
  match_id uuid,
  sender_id uuid,
  text text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  is_read boolean default false,
  constraint messages_match_id_fkey FOREIGN KEY (match_id) REFERENCES matches(id) ON DELETE CASCADE,
  constraint messages_pkey PRIMARY KEY (id),
  constraint messages_sender_id_fkey FOREIGN KEY (sender_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.notifications
create table public.notifications (
  id uuid not null default gen_random_uuid(),
  user_id uuid,
  from_user_id uuid,
  type text,
  title text,
  message text,
  read boolean default false,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  action_url text,
  constraint notifications_from_user_id_fkey FOREIGN KEY (from_user_id) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint notifications_pkey PRIMARY KEY (id),
  constraint notifications_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.poll_options
create table public.poll_options (
  id uuid not null default gen_random_uuid(),
  confession_id uuid,
  text text,
  vote_count integer default 0,
  constraint poll_options_confession_id_fkey FOREIGN KEY (confession_id) REFERENCES confessions(id) ON DELETE CASCADE,
  constraint poll_options_pkey PRIMARY KEY (id)
);

-- Table: public.poll_votes
create table public.poll_votes (
  id uuid not null default gen_random_uuid(),
  confession_id uuid,
  option_id uuid,
  user_id uuid,
  constraint poll_votes_confession_id_fkey FOREIGN KEY (confession_id) REFERENCES confessions(id) ON DELETE CASCADE,
  constraint poll_votes_confession_id_user_id_key UNIQUE (confession_id, user_id),
  constraint poll_votes_option_id_fkey FOREIGN KEY (option_id) REFERENCES poll_options(id) ON DELETE CASCADE,
  constraint poll_votes_pkey PRIMARY KEY (id),
  constraint poll_votes_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.profiles
create table public.profiles (
  id uuid not null,
  anonymous_id text,
  real_name text,
  gender text,
  university text,
  university_email text,
  branch text,
  year text,
  interests text[],
  bio text,
  dob text,
  is_verified boolean default false,
  avatar text,
  is_premium boolean default false,
  updated_at timestamp with time zone default timezone('utc'::text, now()),
  looking_for text[],
  username text,
  constraint profiles_id_fkey FOREIGN KEY (id) REFERENCES auth.users(id) ON DELETE CASCADE,
  constraint profiles_pkey PRIMARY KEY (id),
  constraint profiles_username_key UNIQUE (username)
);

-- Table: public.support_tickets
create table public.support_tickets (
  id uuid not null default gen_random_uuid(),
  user_id uuid,
  email text,
  category text,
  message text,
  status text default 'open'::text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  constraint support_tickets_pkey PRIMARY KEY (id),
  constraint support_tickets_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.swipes
create table public.swipes (
  id uuid not null default gen_random_uuid(),
  liker_id uuid,
  target_id uuid,
  action text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  constraint swipes_liker_id_fkey FOREIGN KEY (liker_id) REFERENCES profiles(id) ON DELETE CASCADE,
  constraint swipes_liker_id_target_id_key UNIQUE (liker_id, target_id),
  constraint swipes_pkey PRIMARY KEY (id),
  constraint swipes_target_id_fkey FOREIGN KEY (target_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.user_presence
create table public.user_presence (
  user_id uuid not null,
  is_online boolean default false,
  last_seen timestamp with time zone default now(),
  updated_at timestamp with time zone default now(),
  constraint user_presence_pkey PRIMARY KEY (user_id),
  constraint user_presence_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

-- Table: public.verification_requests
create table public.verification_requests (
  id uuid not null default gen_random_uuid(),
  user_id uuid,
  email text,
  status text default 'pending'::text,
  created_at timestamp with time zone default timezone('utc'::text, now()),
  constraint verification_requests_pkey PRIMARY KEY (id),
  constraint verification_requests_user_id_fkey FOREIGN KEY (user_id) REFERENCES profiles(id) ON DELETE CASCADE
);

```

